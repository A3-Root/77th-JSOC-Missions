class CfgMusic {
	tracks[] = {};
	class greatest_christmas_song {
		// display name
		name	= "Greatest Christmas Music";

		// filename, volume, pitch
		sound[]	= { "media\audio\greatest_christmas_song.ogg", db + 10, 1.0 };
	};
	class jsoc_christmas_race_song {
		// display name
		name	= "Christmas Race Music";

		// filename, volume, pitch
		sound[]	= { "media\audio\jsoc_christmas_race_song.ogg", db + 10, 1.0 };
	};
	class jsoc_vietnam_christmas {
		name = "JSOC Vietnam Christmas";						// display name
		sound[] = { "media\audio\vietnam_christmas.ogg", 1, 1, 100 };	// file, volume, pitch, maxDistance
	};
	class jsoc_christmas_chatgpt_suno {
		name = "JSOC ChatGPT Christmas";						// display name
		sound[] = { "media\audio\77thChristmasChatGPTSuno.ogg", 1, 1, 100 };	// file, volume, pitch, maxDistance
	};
};

class CfgSounds
{
	sounds[] = {}; // OFP required it filled, now it can be empty or absent depending on the game's version

	class jsoc_christmas_race_countdown {
		name = "Christmas Race Countdown";						// display name
		sound[] = { "media\audio\race_countdown.ogg", 1, 1, 100 };	// file, volume, pitch, maxDistance
		titles[] = {};
	};
	class jsoc_vietnam_christmas {
		name = "JSOC Vietnam Christmas";						// display name
		sound[] = { "media\audio\vietnam_christmas.ogg", 10, 1, 100 };	// file, volume, pitch, maxDistance (increased volume to 10)
		titles[] = {};
	};
	class jsoc_christmas_chatgpt_suno {
		name = "JSOC ChatGPT Christmas";						// display name
		sound[] = { "media\audio\77thChristmasChatGPTSuno.ogg", 1, 1, 100 };	// file, volume, pitch, maxDistance
		titles[] = {};
	};
};